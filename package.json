{
  "name": "riptune",
  "private": true,
  "version": "0.3.0",
  "description": "RipTune - Analyze and download music from YouTube (BPM, Key, Metadata)",
  "author": "Hugo Sohm <no-reply@riptune.app>",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HugoSohm/riptune.git"
  },
  "funding": {
    "type": "ko-fi",
    "url": "https://ko-fi.com/riptune"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "bugs": {
    "url": "https://github.com/HugoSohm/riptune/issues"
  },
  "homepage": "https://riptune.app",
  "keywords": [
    "tauri",
    "rust",
    "react",
    "music-analysis",
    "youtube-downloader",
    "bpm-extractor"
  ],
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env -- tauri dev",
    "build": "dotenv -e .env -- tauri build",
    "frontend:dev": "vite",
    "frontend:build": "tsc && vite build",
    "tauri": "tauri",
    "setup": "node -e \"const { execSync } = require('child_process'); const script = process.platform === 'win32' ? 'powershell ./setup_bin.ps1' : 'sh ./setup_bin.sh'; execSync(script, { stdio: 'inherit' });\""
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-deep-link": "^2.4.8",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "essentia.js": "^0.1.3",
    "lucide-react": "^1.7.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.27",
    "dotenv-cli": "^11.0.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}