{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RipTune",
  "version": "../package.json",
  "identifier": "com.hugz.riptune",
  "build": {
    "beforeDevCommand": "npm run frontend:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run frontend:build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 1280,
        "height": 840,
        "minWidth": 1080,
        "minHeight": 800,
        "decorations": true,
        "transparent": false,
        "backgroundColor": "#0a0f1c",
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 18,
          "y": 30
        },
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "bin/**/*"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "Copyright © 2026 RipTune",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/installer_header.bmp",
        "sidebarImage": "icons/installer_sidebar.bmp",
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/HugoSohm/riptune/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERBNUYxRjAyQTM4Q0Y0QTAKUldTZzlJeWpBaDlmMmtKTzBHRXhPUStkTFhnQmZDK29wMzJZdmhIMTZnZjNoLzdzUG1nK3dKRDYK"
    },
    "deep-link": {
      "desktop": {
        "schemes": ["riptune"]
      }
    }
  }
}